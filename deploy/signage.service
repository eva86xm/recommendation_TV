[Unit]
Description=Digital Signage Flask App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/digital-signage-app
EnvironmentFile=/opt/digital-signage-app/.env
ExecStart=/opt/digital-signage-app/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 app:app
Restart=always

[Install]
WantedBy=multi-user.target
